rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Anyone (future storefront visitors) can read products & categories.
    // Only a signed-in admin can add/edit/delete them.
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Customers will be able to place orders (create) once the storefront
    // exists, but only the admin can view/update/delete them.
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    match /enquiries/{enquiryId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
